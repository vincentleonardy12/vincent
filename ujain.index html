<html>
<head>
<title> Bahan Ujian</title>
<link rel="stylesheet" href="ujain1.css">
</head>
<body>
<div class="kotak">
    <h1> Input Data </h1>
	<label> Name:</label>
	<input type="text" id="name" placeholder="Input Your Name">
	<label> Umur: </label>
	<label>
	    <input type="radio" name="Umur" value="10-12"> 10-12
	</label>
	<label>
	    <input type="radio" name="Umur" value="13-15"> 13-15
	</label>
	<label>
	    <input type="radio" name="Umur" value="16-17"> 16-17
	</label>
	<label> Gender: </label>
	<label>
	    <input type="radio" name="gender" value="laki-laki"> Boy
	</label>
	<label>
	    <input type="radio" name="gender" value="perempuan"> Girl 
	</label>
	<label>
	    <input type="checkbox" id="setuju">Ok saya setuju
	</label>
		<label>Tingkatan: </label>
	<label>
	    <input type="radio" name="Tingkatan" value="SD">SD
	</label>
	<label>
	    <input type="radio" name="Tingkatan" value="SMP"> SMP
	</label>
		<label>
	    <input type="radio" name="Tingkatan" value="SMA"> SMA
	</label>
	<label>
	    <button id="tampil"> Show Your Data </button>
	</label>
	<div class="kotak2" id="hasil">
	    Data Anda akan ditampilkan di sini...
	</div>
</div>
<script src="ujain2.js"></script>
</body>
</html>
